# Copy this file to config.env and edit for your setup. The real config.env is
# gitignored (it names your accounts); this example is committed.

# Swap when the ACTIVE account's 5h utilization is at or above this (0-100).
FIVE_HOUR_PCT=80

# Swap when (max weekly - min weekly) across accounts is at or above this (0-100).
# This is the base dead zone; it tightens adaptively as the lowest account's weekly
# usage (the floor) climbs toward 100, so the rotator keeps rebalancing near the ceiling.
WEEKLY_DIVERGENCE_PCT=10

# Adaptive dead zone: when the floor (min weekly) is at or above HI_FLOOR, the
# divergence threshold shrinks to HI_PCT; at or above VHI_FLOOR it shrinks to VHI_PCT.
WEEKLY_DIVERGENCE_HI_FLOOR=80
WEEKLY_DIVERGENCE_HI_PCT=5
WEEKLY_DIVERGENCE_VHI_FLOOR=90
WEEKLY_DIVERGENCE_VHI_PCT=2.5

# systemd timer cadence, in minutes.
INTERVAL_MIN=15

# Weekly-exhaustion escape valve for the PIN. While an operator PIN is in force, if
# the pinned account's weekly utilization is known and at or above this (0-100), the
# rotator releases the pin for that tick and runs normal rotation (the PIN file is not
# deleted, so it resumes once weekly resets).
WEEKLY_PIN_RELEASE_PCT=98

# Required: space-separated account labels, one per bootstrapped account.
ACCOUNTS="acctA acctB"
