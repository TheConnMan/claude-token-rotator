# Copy this file to config.env and edit for your setup. The real config.env is
# gitignored (it names your accounts); this example is committed.

# Swap when the ACTIVE account's 5h utilization is at or above this (0-100).
FIVE_HOUR_PCT=80

# Swap when (max weekly - min weekly) across accounts is at or above this (0-100).
WEEKLY_DIVERGENCE_PCT=20

# systemd timer cadence, in minutes.
INTERVAL_MIN=15

# Required: space-separated account labels, one per bootstrapped account.
ACCOUNTS="acctA acctB"
